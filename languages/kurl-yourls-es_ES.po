msgstr "Top 10 enlaces de todos los tiempos"

msgid "Last 10 created shortlinks"
msgstr "Últimos 10 enlaces cortos creados"

msgid "Latest shortlinks saved in WordPress"
msgstr "Últimos enlaces cortos guardados en WordPress"

