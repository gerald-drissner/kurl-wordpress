#, python-format
msgid ""
"Version %s • Dashboard statistics, manual shortening, migration tools, logs,"
" and bulk processing."
msgstr ""
"Versión %s • Estadísticas del panel, acortado manual, herramientas de "
"migración, registros y procesamiento masivo."

msgid "API status"
msgstr "Estado de la API"

msgid "Helper extension"
msgstr "Extensión helper"

msgid "Active"
msgstr "Activo"

msgid "Standard API only"
msgstr "Solo API estándar"

msgid "Safe lookup, remote deletion, and reconciliation are available."
msgstr "La búsqueda segura, el borrado remoto y la conciliación están disponibles."

msgid ""
"Install the helper to enable safe lookup, remote deletion, and advanced "
"reconciliation."
msgstr ""
"Instala el helper para habilitar la búsqueda segura, el borrado remoto y la "
"conciliación avanzada."

msgid "Posts currently using a kURL entry in WordPress."
msgstr "Entradas que actualmente usan una entrada de kURL en WordPress."

msgid "Total links reported by YOURLS."
msgstr "Enlaces totales informados por YOURLS."

msgid "Total clicks reported by YOURLS."
msgstr "Clics totales informados por YOURLS."

msgid "Only the last 7 days are retained."
msgstr "Solo se conservan los últimos 7 días."

msgid ""
"The API is not configured yet. You can still review settings, but dashboard "
"lists and manual YOURLS actions will stay inactive until you add your API "
"credentials."
msgstr ""
"La API aún no está configurada. Puedes revisar los ajustes, pero las listas "
"del panel y las acciones manuales de YOURLS seguirán inactivas hasta que "
"añadas tus credenciales de API."

msgid "Manual shortener"
msgstr "Acortador manual"

msgid ""
"Shorten any URL without saving it to WordPress. Safe lookup, delete, and "
"regenerate use the helper plugin when available."
msgstr ""
"Acorta cualquier URL sin guardarla en WordPress. La búsqueda segura, la "
"eliminación y la regeneración usan el helper cuando está disponible."

msgid "Target URL"
msgstr "URL de destino"

msgid ""
"Leave empty to let YOURLS use a random keyword. The Regenerate button uses "
"the keyword field if you filled it in, otherwise it requests a new random "
"keyword."
msgstr ""
"Déjalo vacío para que YOURLS use una palabra clave aleatoria. El botón "
"Regenerar usa el campo de palabra clave si lo has rellenado; de lo contrario"
" solicita una nueva palabra clave aleatoria."

msgid "Delete & Regenerate"
msgstr "Eliminar y regenerar"

msgid ""
"Tip: “Check YOURLS” only performs a safe reverse lookup when the helper "
"plugin is active. “Generate / Update” can still create or return a short URL"
" through the standard API."
msgstr ""
"Consejo: «Comprobar YOURLS» solo realiza una búsqueda inversa segura cuando "
"el helper está activo. «Generar / Actualizar» aún puede crear o devolver una"
" URL corta mediante la API estándar."

